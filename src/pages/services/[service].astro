---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/Icon.astro';
import Faqs from '../../components/Faqs.astro';
import CtaBand from '../../components/CtaBand.astro';
import Reveal from '../../components/Reveal.astro';
import { SITE } from '../../site.config';
import { services } from '../../data/services';
import { locations } from '../../data/locations';
import { breadcrumbSchema, faqSchema, serviceSchema } from '../../lib/schema';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const path = `/services/${service.slug}/`;
const otherServices = services.filter((s) => s.slug !== service.slug).slice(0, 3);
const topLocations = locations.slice(0, 16);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: service.name, href: path },
];
const title = `${service.name} in Wallan & Mitchell Shire`;
const description = `${service.summary} ${service.name} for individuals & businesses across Wallan and the Mitchell Shire. Free consultation — call ${SITE.phone}.`;
const schema = [
  breadcrumbSchema(crumbs),
  serviceSchema({ name: service.name, description: service.summary, path }),
  faqSchema(service.faqs),
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs items={crumbs} />
  <section style="padding-top:28px">
    <div class="container">
      <div class="split">
        <Reveal variant="left">
          <span class="eyebrow">{service.shortName} · Wallan, VIC</span>
          <h1>{service.name} in Wallan &amp; the Mitchell Shire</h1>
          {service.intro.map((p) => <p>{p}</p>)}
          <div class="btn-row">
            <a href={`tel:${SITE.phoneE164}`} class="btn btn-primary">Call now</a>
            <a href="/contact/" class="btn btn-outline">Free Consultation</a>
          </div>
        </Reveal>
        <Reveal variant="right">
          <div class="contact-card">
            <div class="icon-badge"><Icon name={service.icon} class="" /></div>
            <h3 class="mt-0">What’s included</h3>
            <ul class="ticks">
              {service.includes.map((i) => <li>{i}</li>)}
            </ul>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <section class="section-soft">
    <div class="container container-narrow">
      <span class="eyebrow">Who it’s for</span>
      <h2>Is this service right for you?</h2>
      <p class="lead">{service.audience}</p>
      <p>
        Whether you’re in Wallan itself or anywhere across the Mitchell Shire and surrounding region,
        we make {service.name.toLowerCase()} simple, accurate and affordable. Get in touch for a free
        chat about how we can help.
      </p>
    </div>
  </section>

  <!-- Locations served for this service (internal linking) -->
  <section>
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Service areas</span>
        <h2>{service.shortName} across the region</h2>
        <p class="lead">We provide {service.name.toLowerCase()} in these areas and more:</p>
      </div>
      <div class="grid grid-4">
        {topLocations.map((l, i) => (
          <Reveal variant="up" delay={(i % 4) * 0.05}>
            <a class="card" href={`/locations/${l.slug}/${service.slug}/`} style="padding:16px 18px">
              <strong style="color:var(--ink)">{service.shortName} in {l.name}</strong>
              <div style="font-size:0.82rem;color:var(--muted)">{l.name} {l.postcode}</div>
            </a>
          </Reveal>
        ))}
      </div>
      <p style="margin-top:22px"><a href="/locations/" class="btn btn-outline">View all service areas →</a></p>
    </div>
  </section>

  <section class="section-soft">
    <div class="container container-narrow">
      <Faqs items={service.faqs} heading={`${service.name}: your questions answered`} />
    </div>
  </section>

  <!-- Related services -->
  <section>
    <div class="container">
      <div class="section-head"><span class="eyebrow">Related</span><h2>You might also need</h2></div>
      <div class="grid grid-3">
        {otherServices.map((s, i) => (
          <Reveal variant="up" delay={i * 0.08}>
            <a class="card" href={`/services/${s.slug}/`}>
              <div class="icon-badge"><Icon name={s.icon} class="" /></div>
              <h3>{s.name}</h3>
              <p>{s.summary}</p>
              <span class="arrow">Learn more →</span>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <CtaBand title={`Need ${service.shortName.toLowerCase()} you can rely on?`} />
</BaseLayout>

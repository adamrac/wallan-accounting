---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import Reveal from '../../components/Reveal.astro';
import { posts } from '../../data/blog';
import { breadcrumbSchema, articleSchema } from '../../lib/schema';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const path = `/blog/${post.slug}/`;
const related = posts.filter((p) => p.slug !== post.slug).slice(0, 3);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/blog/' },
  { label: post.title, href: path },
];
const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ title: post.title, description: post.description, path, date: post.date }),
];
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout title={post.title} description={post.description} path={path} schema={schema}>
  <Breadcrumbs items={crumbs} />
  <article style="padding-top:28px">
    <div class="container container-narrow">
      <Reveal variant="up">
        <span class="pill">{post.category}</span>
        <h1>{post.title}</h1>
        <p class="muted" style="margin-bottom:1.6rem">{fmt(post.date)} · {post.readMins} min read</p>
      </Reveal>
      <Reveal variant="fade" delay={0.1}>
        <div class="prose" set:html={post.body} />
      </Reveal>
    </div>
  </article>

  <section class="section-soft">
    <div class="container">
      <div class="section-head"><span class="eyebrow">Keep reading</span><h2>Related articles</h2></div>
      <div class="grid grid-3">
        {related.map((p, i) => (
          <Reveal variant="up" delay={i * 0.08}>
            <a class="card" href={`/blog/${p.slug}/`}>
              <span class="pill">{p.category}</span>
              <h3>{p.title}</h3>
              <p>{p.description}</p>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>
  <CtaBand />
</BaseLayout>

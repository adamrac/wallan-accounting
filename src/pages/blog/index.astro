---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import Reveal from '../../components/Reveal.astro';
import { posts } from '../../data/blog';
import { breadcrumbSchema } from '../../lib/schema';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/blog/' },
];
const title = 'Tax & Bookkeeping Resources | Wallan Accounting & Bookkeeping';
const description =
  'Practical tax tips, BAS deadlines, business advice and accounting guides for individuals and small businesses in Wallan and the Mitchell Shire.';
const schema = [breadcrumbSchema(crumbs)];

const sorted = [...posts].sort((a, b) => b.date.localeCompare(a.date));
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout title={title} description={description} path="/blog/" schema={schema}>
  <Breadcrumbs items={crumbs} />
  <section style="padding-top:28px">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Resources &amp; tips</span>
        <h1>Tax &amp; bookkeeping tips for locals</h1>
        <p class="lead">
          Helpful, plain-English guides on tax, BAS, bookkeeping and running a small business in
          Wallan and the Mitchell Shire.
        </p>
      </div>
      <div class="grid grid-3">
        {sorted.map((p, i) => (
          <Reveal variant="up" delay={(i % 3) * 0.08}>
            <a class="card" href={`/blog/${p.slug}/`}>
              <span class="pill">{p.category}</span>
              <h3>{p.title}</h3>
              <p>{p.description}</p>
              <div style="font-size:0.82rem;color:var(--muted);margin-top:10px">{fmt(p.date)} · {p.readMins} min read</div>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>
  <CtaBand />
</BaseLayout>

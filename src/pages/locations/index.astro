---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import Reveal from '../../components/Reveal.astro';
import { locations } from '../../data/locations';
import { breadcrumbSchema } from '../../lib/schema';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/' },
];
const title = 'Service Areas | Accountants Across Mitchell Shire & Beyond';
const description =
  'Wallan Accounting & Bookkeeping serves Wallan, Kilmore, Beveridge, Wandong, Broadford, Seymour, Whittlesea, Mernda, Craigieburn, the Macedon Ranges and the wider region of Victoria.';
const schema = [breadcrumbSchema(crumbs)];

// Group locations by shire for a tidy, scannable directory.
const byShire = locations.reduce<Record<string, typeof locations>>((acc, l) => {
  (acc[l.shire] ||= []).push(l);
  return acc;
}, {});
---
<BaseLayout title={title} description={description} path="/locations/" schema={schema}>
  <Breadcrumbs items={crumbs} />
  <section style="padding-top:28px">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Service areas</span>
        <h1>Local accountants serving the whole region</h1>
        <p class="lead">
          Based in Wallan, we provide tax, bookkeeping, BAS and business services across the Mitchell
          Shire and surrounding councils. Find your town below — or call us wherever you are, we work
          with clients online too.
        </p>
      </div>

      {Object.entries(byShire).map(([shire, towns]) => (
        <div style="margin-bottom:34px">
          <Reveal variant="up"><h2 style="font-size:1.3rem">{shire}</h2></Reveal>
          <div class="grid grid-4">
            {towns.map((l, i) => (
              <Reveal variant="scale" delay={(i % 4) * 0.05}>
                <a class="card" href={`/locations/${l.slug}/`} style="padding:16px 18px">
                  <strong style="color:var(--ink)">{l.name}</strong>
                  <div style="font-size:0.82rem;color:var(--muted)">{l.postcode}</div>
                </a>
              </Reveal>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
  <CtaBand />
</BaseLayout>

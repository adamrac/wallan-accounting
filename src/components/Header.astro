---
import { SITE, NAV } from '../site.config';
---
<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <span class="brand-mark">W</span>
      <span>
        Wallan Accounting
        <small>&amp; Bookkeeping</small>
      </span>
    </a>

    <nav class="nav" id="primary-nav" aria-label="Primary">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/contact/" class="btn btn-primary nav-cta">Free Consultation</a>
    </nav>

    <div class="header-cta">
      <a href={`tel:${SITE.phoneE164}`} class="header-phone">{SITE.phone}</a>
      <a href="/contact/" class="btn btn-primary">Free Consultation</a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="primary-nav">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
</script>

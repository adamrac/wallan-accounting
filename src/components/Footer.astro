---
import { SITE } from '../site.config';
import { services } from '../data/services';
import { locations } from '../data/locations';

const year = new Date().getFullYear();
const footerLocations = locations.slice(0, 10);
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand" style="color:#fff">
          <span class="brand-mark">W</span>
          <span>Wallan Accounting<small style="color:#c9b6e2">&amp; Bookkeeping</small></span>
        </a>
        <p style="margin-top:14px;max-width:34ch">
          Local accountants &amp; bookkeepers serving Wallan and the Mitchell Shire region.
          Individual &amp; business tax, BAS, bookkeeping and payroll. Free consultation.
        </p>
        <p>
          <a href={`tel:${SITE.phoneE164}`} style="font-weight:700;color:#fff;font-size:1.1rem">{SITE.phone}</a>
        </p>
      </div>

      <div>
        <h4>Services</h4>
        <ul class="footer-links">
          {services.slice(0, 7).map((s) => (
            <li><a href={`/services/${s.slug}/`}>{s.shortName}</a></li>
          ))}
          <li><a href="/services/">All services →</a></li>
        </ul>
      </div>

      <div>
        <h4>Service Areas</h4>
        <ul class="footer-links">
          {footerLocations.map((l) => (
            <li><a href={`/locations/${l.slug}/`}>{l.name}</a></li>
          ))}
          <li><a href="/locations/">All areas →</a></li>
        </ul>
      </div>

      <div>
        <h4>Company</h4>
        <ul class="footer-links">
          <li><a href="/about/">About Us</a></li>
          <li><a href="/pricing/">Pricing</a></li>
          <li><a href="/faq/">FAQs</a></li>
          <li><a href="/blog/">Resources &amp; Tips</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
        <p style="margin-top:14px;font-size:0.9rem;color:#c9b6e2">
          {SITE.address.locality}, {SITE.address.region} {SITE.address.postcode}<br />
          Mon–Fri 9am–5pm
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {year} {SITE.name}. All rights reserved.</span>
      <span>Tax &amp; bookkeeping services across Mitchell Shire, Victoria.</span>
    </div>
  </div>
</footer>

---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---
<nav class="crumbs container" aria-label="Breadcrumb">
  <ol>
    {items.map((c) => (
      <li>{c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}</li>
    ))}
  </ol>
</nav>
